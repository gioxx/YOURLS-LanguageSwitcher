#: plugin.php
msgid "Language Switcher"
msgstr "Selettore lingua"

#: inc/helpers.php
msgid "English (default)"
msgstr "Inglese (predefinito)"

#: inc/admin-page.php
msgid "Language Settings"
msgstr "Impostazioni lingua"

#: inc/admin-page.php
msgid "Active Language"
msgstr "Lingua attiva"

#: inc/admin-page.php
msgid "Select the language for the YOURLS admin interface. Only languages with installed translation files appear in this list."
msgstr "Seleziona la lingua per l'interfaccia di amministrazione di YOURLS. Vengono mostrate solo le lingue con i file di traduzione installati."

#: inc/admin-page.php
msgid "No translation files found. Install YOURLS language files in <code>user/languages/</code> to enable language switching."
msgstr "Nessun file di traduzione trovato. Installa i file di lingua di YOURLS nella cartella <code>user/languages/</code> per abilitare il cambio lingua."

#: inc/admin-page.php
msgid "Notes"
msgstr "Note"

#: inc/admin-page.php
msgid "Language switching <strong>requires the corresponding <code>.mo</code> translation file</strong> to be present in the <code>user/languages/</code> directory of your YOURLS installation."
msgstr "Il cambio lingua <strong>richiede il corrispondente file di traduzione <code>.mo</code></strong> nella cartella <code>user/languages/</code> della tua installazione di YOURLS."

#: inc/admin-page.php
msgid "If a language is not listed, its translation file has not been installed — the plugin cannot switch to it."
msgstr "Se una lingua non compare nell'elenco, il suo file di traduzione non è installato — il plugin non può attivarla."

#: inc/admin-page.php
msgid "YOURLS translation files are available in the <a href=\"https://github.com/YOURLS/YOURLS/tree/master/user/languages\" target=\"_blank\" rel=\"noopener noreferrer\">YOURLS GitHub repository</a>."
msgstr "I file di traduzione di YOURLS sono disponibili nel <a href=\"https://github.com/YOURLS/YOURLS/tree/master/user/languages\" target=\"_blank\" rel=\"noopener noreferrer\">repository GitHub di YOURLS</a>."

#: inc/admin-page.php
msgid "Selecting <strong>English (default)</strong> removes any override and falls back to the language set in <code>config.php</code>."
msgstr "Selezionando <strong>Inglese (predefinito)</strong> si rimuove qualsiasi sovrascrittura e si ritorna alla lingua impostata in <code>config.php</code>."

#: inc/admin-page.php
msgid "Save Language"
msgstr "Salva lingua"

#: inc/admin-page.php
msgid "Back to top"
msgstr "Torna all'inizio"

#: inc/admin-page.php
msgid "Language reset to English (default)."
msgstr "Lingua reimpostata su Inglese (predefinito)."

#: inc/admin-page.php
msgid "Selected language is not available. Make sure its translation file is installed."
msgstr "La lingua selezionata non è disponibile. Verifica che il suo file di traduzione sia installato."

#: inc/admin-page.php
msgid "Language updated successfully."
msgstr "Lingua aggiornata con successo."

#: inc/update-check.php
msgid "New version available: <strong>%s</strong>!"
msgstr "Nuova versione disponibile: <strong>%s</strong>!"

#: inc/update-check.php
msgid "View details on GitHub"
msgstr "Visualizza dettagli su GitHub"

#: inc/update-check.php
msgid "Update Available"
msgstr "Aggiornamento disponibile"
